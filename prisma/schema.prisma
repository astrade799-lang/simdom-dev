generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
enum Role {
  SUPER_ADMIN
  ADMIN
  KABID
}

enum WebStatus {
  AKTIF
  TIDAK_AKTIF
  SUSPEND
}

enum ActivityStatus {
  PENDING
  CONFIRMED
  INSTRUCTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  namaLengkap  String?
  nip          String?
jabatan     String?
  password  String
  role      Role     @default(ADMIN)
  skpdId    String?
  skpd      Skpd?    @relation(fields: [skpdId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([skpdId])
}

model Skpd {
  id              String    @id @default(cuid())
  nama            String
  singkatan       String    @unique
  penanggungjawab String
  kontak          String
  users           User[]
  webApps         WebApp[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model WebApp {
  id             String           @id @default(cuid())
  nama           String
  url            String           @unique
  status         WebStatus        @default(AKTIF)
  alasanSuspend  String?
  keterangan     String?
  adminTeknis    String
  kontakAdmin    String
  vendor         String?
  kontakVendor   String?
  platform       String?
  tanggalAktif   DateTime?
  tanggalExpired DateTime?
  auditTeknis  AuditTeknis?
  skpdId         String
  skpd           Skpd             @relation(fields: [skpdId], references: [id])
   activities     ActivityReport[]
  histories      DomainHistory[]
  checks         DomainCheck[] 
  sslChecks            SslCheck[]
  securityHeaderChecks SecurityHeaderCheck[]
  findings             Finding[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([skpdId])
  @@index([status])
}

model ActivityReport {
  id            String         @id @default(cuid())
  jenisKegiatan String
  deskripsi     String
  tanggal       DateTime
  status        ActivityStatus @default(PENDING)
  instruksi     String?
  webAppId      String
  webApp        WebApp         @relation(fields: [webAppId], references: [id])
  createdById   String
  confirmedById String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  buktiUrl    String?

  @@index([webAppId])
  @@index([status])
  @@index([tanggal])
}

model DomainHistory {
  id          String   @id @default(cuid())
  webAppId    String
  webApp      WebApp   @relation(fields: [webAppId], references: [id], onDelete: Cascade)
  userId      String
  userName    String
  action      String   // "UPDATE" | "STATUS_CHANGE" | "DELETE"
  fieldName   String?  // field apa yang berubah
  oldValue    String?  // nilai lama
  newValue    String?  // nilai baru
  createdAt   DateTime @default(now())

  @@index([webAppId])
  @@index([createdAt])
}

model DomainCheck {
  id           String   @id @default(cuid())
  webAppId     String
  webApp       WebApp   @relation(fields: [webAppId], references: [id], onDelete: Cascade)
  isOnline     Boolean
  responseTime Int?     // dalam millisecond
  statusCode   Int?     // HTTP status code
  checkedAt    DateTime @default(now())

  @@index([webAppId])
  @@index([checkedAt])
}

model SslCheck {
  id            String    @id @default(cuid())
  webAppId      String
  webApp        WebApp    @relation(fields: [webAppId], references: [id], onDelete: Cascade)
  isValid       Boolean
  issuer        String?
  expiryDate    DateTime?
  daysRemaining Int?
  checkedAt     DateTime  @default(now())

  @@index([webAppId])
  @@index([checkedAt])
}

model SecurityHeaderCheck {
  id          String   @id @default(cuid())
  webAppId    String
  webApp      WebApp   @relation(fields: [webAppId], references: [id], onDelete: Cascade)
  hasHsts     Boolean  @default(false)
  hasXFrame   Boolean  @default(false)
  hasXContent Boolean  @default(false)
  hasCsp      Boolean  @default(false)
  score       Int?
  checkedAt   DateTime @default(now())

  @@index([webAppId])
  @@index([checkedAt])
}

model Finding {
  id          String            @id @default(cuid())
  webAppId    String
  webApp      WebApp            @relation(fields: [webAppId], references: [id], onDelete: Cascade)
  judul       String
  deskripsi   String?
  severity    String            @default("MEDIUM")
  status      String            @default("OPEN")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  followups   FindingFollowup[]

  @@index([webAppId])
  @@index([status])
}

model FindingFollowup {
  id          String   @id @default(cuid())
  findingId   String
  finding     Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  catatan     String?
  status      String
  createdById String?
  createdAt   DateTime @default(now())

  @@index([findingId])
}

model AuditTeknis {
  id                    String    @id @default(cuid())
  webAppId              String    @unique
  webApp                WebApp    @relation(fields: [webAppId], references: [id], onDelete: Cascade)

  pageSpeedScore        Int?
  pageSpeedPerformance  Int?
  pageSpeedAccessibility Int?
  pageSpeedBestPractices Int?
  pageSpeedSeo          Int?
  pageSpeedCheckedAt    DateTime?

  securityGrade         String?
  securityStatus        String    @default("BELUM_CEK")
  securityUrl           String?

  dnsStatus             String    @default("BELUM_CEK")
  dnsUrl                String?

  teknologi             String?
  catatan               String?

  updatedAt             DateTime  @updatedAt

  @@index([webAppId])
}